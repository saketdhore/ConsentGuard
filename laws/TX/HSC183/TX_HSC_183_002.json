      "required": true,
      "timing": "storage_on_or_after_2026_01_01",
      "content": "Ensure EHRs containing patient information are physically maintained in the United States or a U.S. territory (including cloud/third-party storage).",
      "citation": "§183.002(a)"
    },
    {
      "obligation_id": "EHR_ACCESS_LIMIT_TPO",
      "applies_when": ["tx_ehr_context"],
      "type": "access_control",
      "required": true,
      "content": "Ensure EHR information of Texas residents (other than open data) is accessible only to individuals who require it for duties related to treatment, payment, or health care operations.",
      "citation": "§183.002(b)"
    },
    {
      "obligation_id": "EHR_IMPLEMENT_REASONABLE_SAFEGUARDS",
      "applies_when": ["tx_ehr_context"],
      "type": "security_safeguards",
      "required": true,
      "content": "Implement reasonable administrative, physical, and technical safeguards to protect confidentiality, integrity, and availability of EHR information.",
      "citation": "§183.002(c)"
